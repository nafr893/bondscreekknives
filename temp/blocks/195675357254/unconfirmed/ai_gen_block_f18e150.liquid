{% doc %}
  @prompt
    Create a theme section that displays each variant of a selected product as an individual product card in a grid layout. Each card should show the variant image (or product image as fallback), variant title, price, and an "Add to Cart" button specific to that variant. The section should have a setting to select which product to pull variants from, and a heading setting. Style it to match a premium knife outdoor brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-variant-grid-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-variant-grid-heading-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-variant-grid-items-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-variant-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .ai-variant-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .ai-variant-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    background: {{ block.settings.image_background }};
    overflow: hidden;
  }

  .ai-variant-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ai-variant-card-{{ ai_gen_id }}:hover .ai-variant-card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-variant-card-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.image_background }};
  }

  .ai-variant-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-variant-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
  }

  .ai-variant-card-title-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: {{ block.settings.text_color }};
    text-transform: {{ block.settings.title_transform }};
  }

  .ai-variant-card-price-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.price_size }}px;
    font-weight: 500;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-variant-card-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .ai-variant-card-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-variant-card-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-variant-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-variant-empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-variant-grid-items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-variant-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-variant-grid-items-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-variant-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.65);
    }

    .ai-variant-card-content-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }

    .ai-variant-card-button-{{ ai_gen_id }} {
      padding: 12px 20px;
      font-size: calc({{ block.settings.button_text_size }}px * 0.9);
    }
  }
{% endstyle %}

<variant-grid-{{ ai_gen_id }} class="ai-variant-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-variant-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-variant-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.product != blank %}
      {% assign selected_product = block.settings.product %}
      
      {% if selected_product.variants.size > 0 %}
        <ul class="ai-variant-grid-items-{{ ai_gen_id }}">
          {% for variant in selected_product.variants %}
            <li class="ai-variant-card-{{ ai_gen_id }}" data-variant-id="{{ variant.id }}">
              <div class="ai-variant-card-image-wrapper-{{ ai_gen_id }}">
                {% if variant.image %}
                  <img
                    src="{{ variant.image | image_url: width: 800 }}"
                    alt="{{ variant.image.alt | default: variant.title | escape }}"
                    class="ai-variant-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {% elsif selected_product.featured_image %}
                  <img
                    src="{{ selected_product.featured_image | image_url: width: 800 }}"
                    alt="{{ selected_product.featured_image.alt | default: variant.title | escape }}"
                    class="ai-variant-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {% else %}
                  <div class="ai-variant-card-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-variant-card-content-{{ ai_gen_id }}">
                <h3 class="ai-variant-card-title-{{ ai_gen_id }}">
                  {{ variant.title }}
                </h3>

                <div class="ai-variant-card-price-{{ ai_gen_id }}">
                  {% if variant.compare_at_price > variant.price %}
                    <span style="text-decoration: line-through; opacity: 0.6; margin-right: 8px;">
                      {{ variant.compare_at_price | money }}
                    </span>
                  {% endif %}
                  {{ variant.price | money }}
                </div>

                <button
                  type="button"
                  class="ai-variant-card-button-{{ ai_gen_id }}"
                  data-variant-id="{{ variant.id }}"
                  {% unless variant.available %}disabled{% endunless %}
                >
                  {% if variant.available %}
                    {{ block.settings.button_text }}
                  {% else %}
                    Sold Out
                  {% endif %}
                </button>
              </div>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <div class="ai-variant-empty-state-{{ ai_gen_id }}">
          <p>This product has no variants.</p>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-variant-empty-state-{{ ai_gen_id }}">
        <p>Select a product to display its variants.</p>
      </div>
    {% endif %}
  </div>
</variant-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.buttons = this.querySelectorAll('.ai-variant-card-button-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.buttons.forEach((button) => {
          button.addEventListener('click', (event) => {
            if (button.disabled) return;

            const variantId = button.dataset.variantId;
            this.addToCart(variantId, button);
          });
        });
      }

      addToCart(variantId, button) {
        const originalText = button.textContent;
        button.textContent = 'Adding...';
        button.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            id: variantId,
            quantity: 1
          })
        })
        .then(response => response.json())
        .then(data => {
          button.textContent = 'Added!';
          
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);

          document.dispatchEvent(new CustomEvent('cart:refresh'));
          
          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer) {
            cartDrawer.open();
          }
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
          button.textContent = 'Error';
          
          setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 2000);
        });
      }
    }

    customElements.define('variant-grid-{{ ai_gen_id }}', VariantGrid{{ ai_gen_id }});
  })();
</script>

